PORT=3000
DATABASE_HOST=localhost
DATABASE_PORT=5434
DATABASE_NAME=nest_batch_demo
DATABASE_USER=demo
DATABASE_PASSWORD=demo

# Batch transport — leave unset (or set to `bullmq`) for the
# @nest-batch/bullmq transport; set to `in-process` to run the
# JobLauncher in-process with the InProcessExecutionStrategy.
BATCH_TRANSPORT=bullmq

# Redis connection (only used when BATCH_TRANSPORT=bullmq).
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Optional override of the import CSV path used by the
# `import-products` job's default registration.
IMPORT_FILE=sample-data/products-valid.csv
