PORT=3000

# --- PostgreSQL (matches docker-compose.yml) ----------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5434
DATABASE_NAME=nest_batch_demo
DATABASE_USER=demo
DATABASE_PASSWORD=demo

# --- Batch transport ----------------------------------------------------
# `bullmq`    — wire @nest-batch/bullmq as the execution strategy
#               (default; launcher enqueues, worker consumes).
# `in-process` — wire the in-process strategy, no Redis required.
BATCH_TRANSPORT=bullmq

# --- Redis (only read when BATCH_TRANSPORT=bullmq) ----------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Optional. Defaults to `nest-batch:` inside @nest-batch/bullmq when
# unset. Useful for the e2e suite to isolate parallel runs.
# REDIS_KEY_PREFIX=nest-batch:

# --- Demo inputs --------------------------------------------------------
# Path the demo's `import-products` job reads by default. Overridable
# per-launch via the REST controller's request body.
IMPORT_FILE=sample-data/products-valid.csv

# --- Test-only escape hatches (do NOT set in production) ----------------
# Set to `1` to put cron-decorated jobs into inert mode at decoration
# time. The @BatchScheduled decorator captures this env var; the
# runtime scheduler honors it. See packages/core README.
# BATCH_SCHEDULED_DISABLE=0

# Set to `1` to start a BullMQ Worker in the same process as the
# launcher. The demo is launcher-only by default (the worker is a
# separate deployment); the e2e suite flips this on so the test can
# assert the full enqueue → consume → DB-update cycle in one process.
# BATCH_BULLMQ_AUTOSTART_WORKER=0

# Override the BullMQ key prefix. The e2e suite sets this to a per-PID
# value so concurrent runs do not collide on shared Redis state.
# BATCH_BULLMQ_KEY_PREFIX=
