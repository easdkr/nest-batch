# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# Coverage
coverage/
*.lcov

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# OMO (orchestrator state — plans, notepads, evidence, run state, boulder)
# Entire subtree is per-machine state; never check in.
.omo/

# Test artifacts
.jest-cache/
.vitest-cache/

# MikroORM migrator auto-generated schema snapshots. The migrator
# writes one of these per database it touches, into the package's
# `migrations/` directory. The project uses raw-SQL migrations
# (`this.addSql(...)`), not entity-diff-based ones, so the snapshot
# is incidental and per-machine.
**/migrations/.snapshot-*.json
