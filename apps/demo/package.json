{
  "name": "@nest-batch/demo",
  "version": "0.1.0",
  "private": true,
  "main": "dist/src/main.js",
  "scripts": {
    "build": "swc src -d dist --config-file ../../.swcrc",
    "start": "node dist/src/main.js",
    "start:dev": "swc src -d dist --watch & node dist/src/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "migration:create": "mikro-orm migration:create",
    "migration:up": "mikro-orm migration:up"
  },
  "dependencies": {
    "@mikro-orm/core": "^6.0.0",
    "@mikro-orm/migrations": "^6.0.0",
    "@mikro-orm/nestjs": "^6.0.0",
    "@mikro-orm/postgresql": "^6.0.0",
    "@nest-batch/bullmq": "workspace:*",
    "@nest-batch/core": "workspace:*",
    "@nest-batch/mikro-orm": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "csv-parse": "^5.5.0",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^6.0.0",
    "@nestjs/testing": "^11.0.0",
    "@swc/cli": "^0.4.0",
    "@swc/core": "^1.7.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.10.0",
    "@types/supertest": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}