{
  "name": "nest-batch-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "NestJS batch processing monorepo (library + demo app)",
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "pretest:e2e": "docker info >/dev/null 2>&1 || { echo \"Docker is required for e2e tests. Install Docker or run unit tests with: pnpm test\" >&2; exit 1; }",
    "test:e2e": "pnpm -r --workspace-concurrency=1 run test:e2e",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@swc/cli": "^0.7.0",
    "@swc/core": "^1.10.7",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "^2.1.8"
  }
}
