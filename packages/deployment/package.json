{
  "name": "@nest-batch/deployment",
  "version": "0.2.1",
  "description": "Deployment recipes and IaC helper objects for nest-batch runtime adapters.",
  "license": "MIT",
  "author": "easdkr",
  "homepage": "https://github.com/easdkr/nest-batch/tree/main/packages/deployment#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/easdkr/nest-batch.git",
    "directory": "packages/deployment"
  },
  "bugs": {
    "url": "https://github.com/easdkr/nest-batch/issues"
  },
  "keywords": [
    "nestjs",
    "batch",
    "deployment",
    "iac",
    "cdk"
  ],
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
