{
  "name": "@nest-batch/kafka",
  "version": "0.2.0",
  "description": "Kafka runtime adapter for @nest-batch/core — runs batch jobs and partitioned steps as Kafka messages.",
  "license": "MIT",
  "author": "easdkr",
  "homepage": "https://github.com/easdkr/nest-batch/tree/main/packages/kafka#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/easdkr/nest-batch.git",
    "directory": "packages/kafka"
  },
  "bugs": {
    "url": "https://github.com/easdkr/nest-batch/issues"
  },
  "keywords": [
    "nestjs",
    "batch",
    "spring-batch",
    "kafka",
    "message-queue"
  ],
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "swc src -d dist --config-file ../../.swcrc && tsc --emitDeclarationOnly -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@nest-batch/core": "workspace:^",
    "@nestjs/common": "^10 || ^11",
    "@nestjs/core": "^10 || ^11",
    "kafkajs": "^2.2.4"
  },
  "peerDependenciesMeta": {
    "@nest-batch/core": {
      "optional": false
    },
    "@nestjs/common": {
      "optional": false
    },
    "@nestjs/core": {
      "optional": false
    },
    "kafkajs": {
      "optional": false
    }
  },
  "devDependencies": {
    "@nest-batch/core": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@swc/cli": "^0.7.0",
    "@swc/core": "^1.10.7",
    "@types/node": "^22.0.0",
    "kafkajs": "^2.2.4",
    "reflect-metadata": "^0.2.2",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
