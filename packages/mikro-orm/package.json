{
  "name": "@nest-batch/mikro-orm",
  "version": "0.3.0",
  "description": "MikroORM adapter SLOT for @nest-batch/core — JobRepository and TransactionManager interface shape, paired with @nest-batch/postgresql (Postgres driver) or @nest-batch/mysql (MySQL driver).",
  "license": "MIT",
  "author": "easdkr",
  "homepage": "https://github.com/easdkr/nest-batch/tree/main/packages/mikro-orm#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/easdkr/nest-batch.git",
    "directory": "packages/mikro-orm"
  },
  "bugs": {
    "url": "https://github.com/easdkr/nest-batch/issues"
  },
  "keywords": [
    "nestjs",
    "batch",
    "mikro-orm",
    "job-repository",
    "persistence"
  ],
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "swc src -d dist --config-file ../../.swcrc && tsc --emitDeclarationOnly -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@mikro-orm/core": "^6.0.0",
    "@mikro-orm/nestjs": "^6.0.0",
    "@nest-batch/core": "workspace:^",
    "@nestjs/common": "^10 || ^11"
  },
  "peerDependenciesMeta": {
    "@nest-batch/core": {
      "optional": false
    },
    "@nestjs/common": {
      "optional": false
    },
    "@mikro-orm/core": {
      "optional": false
    },
    "@mikro-orm/nestjs": {
      "optional": false
    }
  },
  "devDependencies": {
    "@mikro-orm/core": "^6.0.0",
    "@mikro-orm/nestjs": "^6.0.0",
    "@nest-batch/core": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@swc/cli": "^0.7.0",
    "@swc/core": "^1.10.7",
    "@types/node": "^22.0.0",
    "reflect-metadata": "^0.2.2",
    "typescript": "^5.5.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^2.0.0"
  }
}
