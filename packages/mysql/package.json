{
  "name": "@nest-batch/mysql",
  "version": "0.2.0",
  "description": "MySQL driver shells for @nest-batch/core. Provides 4 MySQL adapter shells (MikroORM MySQL, TypeORM MySQL, Drizzle MySQL, Prisma MySQL), the 6-table MySQL DDL migration, the bundled MySQL Prisma schema, and the shared test-contracts e2e harness against a real MySQL 8.x testcontainer.",
  "license": "MIT",
  "author": "easdkr",
  "homepage": "https://github.com/easdkr/nest-batch/tree/main/packages/mysql#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/easdkr/nest-batch.git",
    "directory": "packages/mysql"
  },
  "bugs": {
    "url": "https://github.com/easdkr/nest-batch/issues"
  },
  "keywords": [
    "nestjs",
    "batch",
    "spring-batch",
    "mysql",
    "mikro-orm",
    "typeorm",
    "drizzle",
    "prisma",
    "job-repository",
    "persistence"
  ],
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src",
    "src",
    "prisma",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "swc src -d dist --config-file ../../.swcrc && tsc --emitDeclarationOnly -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@nest-batch/core": "workspace:^",
    "@nest-batch/mikro-orm": "workspace:^",
    "@nest-batch/typeorm": "workspace:^",
    "@nest-batch/drizzle": "workspace:^",
    "@nest-batch/prisma": "workspace:^",
    "@nestjs/common": "^10 || ^11",
    "@mikro-orm/mysql": "^6.0.0",
    "mysql2": "^3.0.0",
    "drizzle-orm": "^0.40.0",
    "prisma": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@nest-batch/core": {
      "optional": false
    },
    "@nest-batch/mikro-orm": {
      "optional": false
    },
    "@nest-batch/typeorm": {
      "optional": false
    },
    "@nest-batch/drizzle": {
      "optional": false
    },
    "@nest-batch/prisma": {
      "optional": false
    },
    "@nestjs/common": {
      "optional": false
    },
    "@mikro-orm/mysql": {
      "optional": false
    },
    "mysql2": {
      "optional": false
    },
    "drizzle-orm": {
      "optional": false
    },
    "prisma": {
      "optional": false
    }
  },
  "devDependencies": {
    "@mikro-orm/core": "^6.0.0",
    "@mikro-orm/mysql": "^6.0.0",
    "@nest-batch/core": "workspace:*",
    "@nest-batch/mikro-orm": "workspace:*",
    "@nest-batch/typeorm": "workspace:*",
    "@nest-batch/drizzle": "workspace:*",
    "@nest-batch/prisma": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "@swc/cli": "^0.7.0",
    "@swc/core": "^1.10.7",
    "@testcontainers/mysql": "^12.0.1",
    "@types/node": "^22.0.0",
    "drizzle-orm": "^0.40.0",
    "mysql2": "^3.0.0",
    "reflect-metadata": "^0.2.0",
    "testcontainers": "^12.0.1",
    "typeorm": "^1.0.0",
    "typescript": "^5.5.0",
    "unplugin-swc": "^1.5.0",
    "vitest": "^2.0.0"
  }
}
