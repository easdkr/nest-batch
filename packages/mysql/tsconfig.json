{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDirs": ["src", "tests"],
    "baseUrl": ".",
    "paths": {
      "@nest-batch/core": ["../core/src/index.ts"],
      "@nest-batch/core/test-contracts": ["../core/tests/contracts/index.ts"],
      "@nest-batch/mikro-orm": ["../mikro-orm/src/index.ts"],
      "@nest-batch/typeorm": ["../typeorm/src/index.ts"],
      "@nest-batch/drizzle": ["../drizzle/src/index.ts"],
      "@nest-batch/prisma": ["../prisma/src/index.ts"],
      "@nest-batch/mysql": ["../mysql/src/index.ts"]
    }
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}
