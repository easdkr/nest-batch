{
  "name": "@nest-batch/postgresql",
  "version": "0.3.0",
  "description": "PostgreSQL driver shells for @nest-batch/core. Provides 4 Postgres adapter shells (MikroORM, TypeORM, Drizzle, Prisma), the 5-table Postgres DDL migration, the bundled Postgres Prisma schema, and the shared test-contracts e2e harness against a real Postgres testcontainer.",
  "license": "MIT",
  "author": "easdkr",
  "homepage": "https://github.com/easdkr/nest-batch/tree/main/packages/postgresql#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/easdkr/nest-batch.git",
    "directory": "packages/postgresql"
  },
  "bugs": {
    "url": "https://github.com/easdkr/nest-batch/issues"
  },
  "keywords": [
    "nestjs",
    "batch",
    "postgresql",
    "postgres",
    "mikro-orm",
    "typeorm",
    "drizzle",
    "prisma",
    "job-repository",
    "persistence"
  ],
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src",
    "src",
    "migrations",
    "prisma",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "swc src -d dist --config-file ../../.swcrc && tsc --emitDeclarationOnly -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "RUN_POSTGRES_E2E=1 vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@nest-batch/core": "workspace:^",
    "@nest-batch/drizzle": "workspace:^",
    "@nest-batch/mikro-orm": "workspace:^",
    "@nest-batch/prisma": "workspace:^",
    "@nest-batch/typeorm": "workspace:^",
    "@nestjs/common": "^10 || ^11",
    "@mikro-orm/core": "^6.0.0",
    "@mikro-orm/postgresql": "^6.0.0",
    "@nestjs/typeorm": "^10 || ^11",
    "@prisma/client": "^6.0.0",
    "drizzle-orm": "^0.40.0",
    "pg": "^8.11.0",
    "prisma": "^6.0.0",
    "typeorm": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@nest-batch/core": {
      "optional": false
    },
    "@nest-batch/mikro-orm": {
      "optional": false
    },
    "@nest-batch/typeorm": {
      "optional": false
    },
    "@nest-batch/drizzle": {
      "optional": false
    },
    "@nest-batch/prisma": {
      "optional": false
    },
    "@nestjs/common": {
      "optional": false
    }
  },
  "devDependencies": {
    "@nest-batch/core": "workspace:*",
    "@nest-batch/drizzle": "workspace:*",
    "@nest-batch/mikro-orm": "workspace:*",
    "@nest-batch/prisma": "workspace:*",
    "@nest-batch/typeorm": "workspace:*",
    "@mikro-orm/core": "^6.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "@swc/cli": "^0.7.0",
    "@swc/core": "^1.10.7",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-orm": "^0.40.0",
    "pg": "^8.21.0",
    "prisma": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "testcontainers": "^12.0.1",
    "typescript": "^5.5.0",
    "typeorm": "^1.0.0",
    "unplugin-swc": "^1.5.0",
    "vitest": "^2.0.0"
  }
}
