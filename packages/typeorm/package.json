{
  "name": "@nest-batch/typeorm",
  "version": "0.1.0",
  "private": true,
  "description": "TypeORM 1.0.0 adapter for @nest-batch/core. Provides TypeOrmJobRepository and TypeOrmTransactionManager, owns the six Spring Batch-compatible batch meta tables (entities + migration), and runs the shared contract suite against a real TypeORM DataSource.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "swc src -d dist --config-file ../../.swcrc && tsc --emitDeclarationOnly -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@nest-batch/core": "workspace:*",
    "@nestjs/common": "^10 || ^11",
    "@nestjs/typeorm": "^10 || ^11",
    "typeorm": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "typeorm": {
      "optional": false
    },
    "@nest-batch/core": {
      "optional": false
    },
    "@nestjs/common": {
      "optional": false
    },
    "@nestjs/typeorm": {
      "optional": false
    }
  },
  "devDependencies": {
    "@nest-batch/core": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@swc/cli": "^0.7.0",
    "@swc/core": "^1.10.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "better-sqlite3": "^12.0.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^1.0.0",
    "typescript": "^5.5.0",
    "unplugin-swc": "^1.5.0",
    "vitest": "^2.0.0"
  }
}
